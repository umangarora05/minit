# Use Node.js 20 Alpine for a small footprint
FROM node:20-alpine

# Set working directory
WORKDIR /app

# Copy package files for dependency installation
COPY package*.json ./

# Install only production dependencies
RUN npm install --production

# Copy the source code (including src/config, src/kafka, etc.)
COPY . .

# Expose the delivery port
EXPOSE 5004

# Run the server
CMD ["node", "server.js"]